{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "clinical_extraction.v1",
  "title": "ClinicalExtraction",
  "description": "Structured output contract for the Structuring adapter. See TDD §10.2, §11.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "summary",
    "document_date",
    "lab_name",
    "labs",
    "medications",
    "diagnoses",
    "vaccinations",
    "clinical_notes"
  ],
  "properties": {
    "document_type": {
      "type": "string",
      "enum": [
        "lab_report",
        "prescription",
        "discharge_summary",
        "radiology",
        "vaccination_card",
        "other"
      ]
    },
    "summary": { "type": "string" },
    "document_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "lab_name": { "type": ["string", "null"] },
    "labs": {
      "type": "array",
      "items": { "$ref": "#/definitions/labEntry" }
    },
    "medications": {
      "type": "array",
      "items": { "$ref": "#/definitions/medicationEntry" }
    },
    "diagnoses": {
      "type": "array",
      "items": { "$ref": "#/definitions/diagnosisEntry" }
    },
    "vaccinations": {
      "type": "array",
      "items": { "$ref": "#/definitions/vaccinationEntry" }
    },
    "clinical_notes": { "type": ["string", "null"] }
  },
  "definitions": {
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "isoDate": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "labEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_name_raw",
        "test_name_normalized",
        "value_text",
        "value_numeric",
        "unit",
        "reference_range",
        "flag",
        "test_category",
        "test_date",
        "confidence"
      ],
      "properties": {
        "test_name_raw": { "type": "string" },
        "test_name_normalized": { "type": "string" },
        "value_text": { "type": "string" },
        "value_numeric": { "type": ["number", "null"] },
        "unit": { "type": ["string", "null"] },
        "reference_range": { "type": ["string", "null"] },
        "flag": {
          "type": "string",
          "enum": ["normal", "low", "high", "critical", "unknown"]
        },
        "test_category": {
          "type": "string",
          "enum": ["Hematology", "Biochemistry", "Microbiology", "Imaging", "Other"]
        },
        "test_date": { "$ref": "#/definitions/isoDate" },
        "confidence": { "$ref": "#/definitions/confidence" }
      }
    },
    "medicationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drug", "dose", "frequency", "duration", "confidence"],
      "properties": {
        "drug": { "type": "string" },
        "dose": { "type": ["string", "null"] },
        "frequency": { "type": ["string", "null"] },
        "duration": { "type": ["string", "null"] },
        "confidence": { "$ref": "#/definitions/confidence" }
      }
    },
    "diagnosisEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "icd10", "confidence"],
      "properties": {
        "text": { "type": "string" },
        "icd10": { "type": ["string", "null"] },
        "confidence": { "$ref": "#/definitions/confidence" }
      }
    },
    "vaccinationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vaccine_name_raw",
        "vaccine_name_normalized",
        "dose_number",
        "date_given",
        "site",
        "batch_no",
        "confidence"
      ],
      "properties": {
        "vaccine_name_raw": { "type": "string" },
        "vaccine_name_normalized": { "type": "string" },
        "dose_number": { "type": ["integer", "null"] },
        "date_given": { "$ref": "#/definitions/isoDate" },
        "site": { "type": ["string", "null"] },
        "batch_no": { "type": ["string", "null"] },
        "confidence": { "$ref": "#/definitions/confidence" }
      }
    }
  }
}
