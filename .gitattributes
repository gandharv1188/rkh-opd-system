# Line-ending policy — authoritative.
#
# Stops the "LF will be replaced by CRLF" warnings on Windows by telling
# git exactly how to handle each file type. Git will honor these rules
# and ignore core.autocrlf for anything matched here.

# Default: text files are normalized to LF in the repo, checked out as LF on
# every platform. No automatic conversion.
* text=auto eol=lf

# Source + docs — LF always, both in repo and working tree.
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.jsonl    text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.sql      text eol=lf
*.sh       text eol=lf
*.py       text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf
.editorconfig    text eol=lf
.prettierrc*     text eol=lf
.eslintrc*       text eol=lf
Dockerfile       text eol=lf

# Windows-native artifacts — CRLF on checkout so they work with Windows tools.
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary — never convert. (Explicit marking avoids accidental corruption.)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.tar.gz   binary
*.tgz      binary
*.xlsx     binary
*.docx     binary
*.pptx     binary
*.woff     binary
*.woff2    binary
*.ttf      binary
