# dbmate env — copy to dbmate.env (gitignored) and fill in real values.
# Used by `dis/scripts/migrate.sh` to drive `npx dbmate up/down/status`.
#
# POC (Supabase) — point at a throwaway local Postgres for now.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dis_test?sslmode=disable

# Where dbmate looks for SQL files. Forward + rollback files live side by side.
DBMATE_MIGRATIONS_DIR=./migrations

# Disable dbmate's default schema-file dump (we do not commit schema.sql).
DBMATE_NO_DUMP_SCHEMA=1

# Future: AWS-stack override (SQS replaces M-004; handled by wrapper filter).
# DIS_STACK=supabase
